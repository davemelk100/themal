{
  "name": "@theemel/editor",
  "version": "0.10.1",
  "type": "module",
  "description": "Interactive design system editor — pick colors, enforce WCAG AA contrast, export CSS custom properties",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "axe-core": ">=4.0.0",
    "lucide-react": ">=0.294.0"
  },
  "peerDependenciesMeta": {
    "axe-core": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/davemelk100/design-alive.git",
    "directory": "packages/editor"
  },
  "keywords": [
    "design-system",
    "css-variables",
    "react",
    "color-picker",
    "wcag",
    "accessibility"
  ],
  "homepage": "https://github.com/davemelk100/design-alive/tree/main/packages/editor"
}
