{
  "application": {
    "name": "Dave Melkonian Portfolio",
    "type": "Personal Portfolio Website",
    "description": "A modern, responsive portfolio website for Dave Melkonian, a Senior UX and Product Designer with 15+ years of experience. Features design work showcase, articles, music player, and interactive animations.",
    "version": "0.1.0",
    "framework": "React + TypeScript + Vite",
    "styling": "Tailwind CSS + Framer Motion"
  },
  "architecture": {
    "frontend": {
      "framework": "React 18",
      "language": "TypeScript",
      "buildTool": "Vite",
      "routing": "React Router DOM",
      "stateManagement": "React Hooks (useState, useEffect)",
      "animations": "Framer Motion",
      "styling": "Tailwind CSS",
      "uiComponents": "Radix UI + Custom Components"
    },
    "deployment": {
      "platform": "Netlify",
      "staticSite": true,
      "serviceWorker": true
    }
  },
  "fileStructure": {
    "src": {
      "components": "Reusable UI components",
      "pages": "Route-based page components",
      "utils": "Utility functions and helpers",
      "data": "Static data and configurations",
      "context": "React context providers",
      "hooks": "Custom React hooks",
      "assets": "Static assets"
    },
    "public": {
      "audio": "MP3 audio files for music player",
      "img": "Images and SVG animations",
      "video": "Video files",
      "_headers": "Netlify headers configuration",
      "_redirects": "Netlify redirects configuration"
    }
  },
  "keyFeatures": {
    "navigation": {
      "type": "Single Page Application with smooth scrolling",
      "sections": [
        "Lab (Current Projects)",
        "Articles",
        "Design Work",
        "Storytelling",
        "Career",
        "Design System"
      ],
      "mobileMenu": "Responsive mobile tray menu",
      "themeToggle": "Dark/Light mode switching"
    },
    "contentSections": {
      "hero": {
        "description": "Main landing section with animated title and navigation",
        "components": [
          "Animated title",
          "Navigation links",
          "Summary text",
          "Video carousel"
        ]
      },
      "lab": {
        "description": "Current projects showcase with grid/list view toggle",
        "features": ["Project cards", "View mode switching", "Archive link"]
      },
      "articles": {
        "description": "Written content with modal display",
        "features": ["Article cards", "Modal popup", "Grid/list view"]
      },
      "design": {
        "description": "Design work portfolio",
        "features": ["Project showcase", "External links", "Categories"]
      },
      "stories": {
        "description": "Storytelling section",
        "features": ["Story cards", "Modal display", "Grid/list view"]
      },
      "career": {
        "description": "Professional experience and background",
        "features": ["Timeline", "Skills", "Experience"]
      },
      "designSystem": {
        "description": "Design system documentation",
        "features": ["Component library", "Typography", "Color system"]
      }
    },
    "musicPlayer": {
      "description": "Full-featured audio player with instrumental tracks",
      "features": [
        "Play/pause controls",
        "Volume control",
        "Progress bar",
        "Track switching",
        "Instrumental version toggle",
        "Playlist management"
      ],
      "audioFormats": "MP3",
      "trackCount": 18,
      "instrumentalTracks": 8
    },
    "animations": {
      "type": "SVG-based animations",
      "carousel": {
        "description": "Video card carousel with animated transitions",
        "slides": [
          "Axonometric Projection (rotating 3D cube)",
          "Observed Rhythm (flowing waves and pulsing dots)"
        ],
        "navigation": "Previous/Next buttons",
        "autoPlay": false
      },
      "svgAnimations": {
        "axonometric": "Rotating 3D cube with muted colors",
        "observedRhythm": "Flowing wave paths with pulsing dots",
        "colors": ["#ff6b6b", "#4ecdc4", "#45b7d1"]
      }
    }
  },
  "designSystem": {
    "typography": {
      "primaryFont": "DM Sans",
      "fontWeights": ["300", "400", "500", "600", "700"],
      "fontSizes": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem",
        "2xl": "1.5rem",
        "3xl": "1.875rem",
        "4xl": "2.25rem",
        "5xl": "3rem",
        "hero": "clamp(6rem, 15vw, 16rem)",
        "display": "clamp(8rem, 20vw, 24rem)"
      }
    },
    "colors": {
      "light": {
        "background": "white",
        "text": "gray-900",
        "muted": "gray-600"
      },
      "dark": {
        "background": "gray-900",
        "text": "white",
        "muted": "gray-300"
      },
      "accent": {
        "primary": "#ff6b6b",
        "secondary": "#4ecdc4",
        "tertiary": "#45b7d1"
      }
    },
    "spacing": {
      "container": "max-w-[1200px]",
      "padding": "px-4 sm:px-8",
      "gap": "gap-8 lg:gap-12"
    },
    "components": {
      "cards": {
        "style": "Rounded corners with shadow",
        "hover": "Scale and shadow transition",
        "variants": ["Project cards", "Article cards", "Story cards"]
      },
      "buttons": {
        "style": "Rounded with hover states",
        "variants": ["Primary", "Secondary", "Ghost", "Icon"]
      },
      "modals": {
        "style": "Overlay with backdrop blur",
        "animation": "Fade in/out with scale"
      }
    }
  },
  "dataStructure": {
    "content": {
      "siteInfo": {
        "title": "Dave Melkonian",
        "subtitle": "Dave Melkonian",
        "description": "Digital Experience Designer"
      },
      "navigation": {
        "links": "Array of navigation items with id and text",
        "social": "LinkedIn and Dribbble links"
      },
      "sections": {
        "work": "Design projects with images and descriptions",
        "articles": "Written content with titles and content",
        "stories": "Storytelling content",
        "lab": "Current projects"
      }
    },
    "audioTracks": {
      "structure": {
        "id": "number",
        "title": "string",
        "artist": "string",
        "url": "string",
        "uniqueUrl": "string",
        "duration": "string",
        "filename": "string",
        "isInstrumental": "boolean",
        "instrumentalUrl": "string (optional)"
      },
      "totalTracks": 18,
      "instrumentalTracks": 8,
      "artists": ["BALM"]
    }
  },
  "animations": {
    "framerMotion": {
      "variants": {
        "fadeIn": "Opacity and y-axis movement",
        "scale": "Transform scale with spring",
        "slideIn": "X-axis movement"
      },
      "transitions": {
        "duration": "0.3-1.8 seconds",
        "easing": "ease-in-out"
      }
    },
    "svgAnimations": {
      "techniques": [
        "CSS keyframes",
        "SMIL animate elements",
        "Transform animations",
        "Stroke-dasharray animations"
      ],
      "durations": {
        "slow": "30-40 seconds",
        "medium": "15-20 seconds",
        "fast": "8-10 seconds"
      }
    }
  },
  "performance": {
    "optimizations": {
      "lazyLoading": "React.lazy for route-based code splitting",
      "imageOptimization": "WebP format with fallbacks",
      "audioOptimization": "MP3 format for web compatibility",
      "animationOptimization": "SVG animations for lightweight graphics"
    },
    "caching": {
      "serviceWorker": "Offline functionality",
      "staticAssets": "Long-term caching for images and audio"
    }
  },
  "accessibility": {
    "features": [
      "ARIA labels for interactive elements",
      "Keyboard navigation support",
      "Screen reader compatibility",
      "High contrast mode support",
      "Focus management"
    ],
    "standards": "WCAG 2.1 AA compliance"
  },
  "responsiveDesign": {
    "breakpoints": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1200px"
    },
    "mobileFirst": true,
    "adaptiveComponents": [
      "Responsive navigation",
      "Mobile tray menu",
      "Adaptive typography",
      "Flexible layouts"
    ]
  },
  "development": {
    "scripts": {
      "dev": "vite",
      "build": "tsc && vite build",
      "preview": "vite preview"
    },
    "dependencies": {
      "core": ["react", "react-dom", "react-router-dom"],
      "ui": ["@radix-ui/react-*", "lucide-react"],
      "styling": ["tailwindcss", "framer-motion"],
      "forms": ["react-hook-form", "zod"],
      "utils": ["clsx", "tailwind-merge", "date-fns"]
    }
  },
  "deployment": {
    "platform": "Netlify",
    "configuration": {
      "_headers": "Security and caching headers",
      "_redirects": "URL redirects and rewrites",
      "buildSettings": "Vite build output"
    }
  },
  "contentManagement": {
    "type": "Static content with potential admin panel",
    "dataSources": {
      "content": "src/content.ts",
      "audio": "src/data/audioUrls.ts",
      "images": "public/img/",
      "audio": "public/audio/"
    },
    "adminFeatures": {
      "status": "In development",
      "features": ["Content editing", "Audio management", "Project updates"]
    }
  }
}
